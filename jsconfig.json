{
    "compilerOptions": {
        "baseUrl": "./",
        "paths": {
            "@app/*": ["src/app/*"],
            "@assets/*": ["src/assets/*"],
            "@components/*": ["src/components/*"],
            "@constants/*": ["src/constants/*"],
            "@context/*": ["src/context/*"],
            "@data/*": ["src/data/*"],
            "@features/*": ["src/features/*"],
            "@hooks/*": ["src/hooks/*"],
            "@services/*": ["src/services/*"],
            "@utils/*": ["src/utils/*"]
        },
        "ignoreDeprecations": "6.0"
  },
  "exclude": ["node_modules", "babel.config.js", "metro.config.js"]
}
